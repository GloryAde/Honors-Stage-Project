@page "/Inventory"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations

<PageTitle>Inventory Management - HSP Library</PageTitle>

<div class="container mt-5">
    <div class="page-header mb-5 text-center">
        <h1 class="display-3">EQUIPMENT INVENTORY</h1>
        <p class="lead">Browse Technology & Gear for Your Projects</p>
        <hr class="my-4" />
    </div>

    <AuthorizeView Roles="Admin,Teacher">
        <Authorized>
            <div class="action-buttons mb-4 text-center">
                <button class="btn btn-primary btn-lg" @onclick="ShowAddAssetForm">
                    <i class="bi bi-plus-circle"></i> Add New Equipment
                </button>
                <button class="btn btn-success btn-lg" @onclick="DownloadAssetListAsync" disabled="@(assets == null || !assets.Any())">
                    <i class="bi bi-download"></i> Download Asset List
                </button>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- Search and View Toggle -->
    @if (assets != null && assets.Any())
    {
        <div class="card modern-card mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <label for="equipmentSearch" class="form-label mb-0">
                        <i class="bi bi-search me-1"></i>Search Equipment
                    </label>
                    <label class="form-label mb-0">
                        <i class="bi bi-eye me-1"></i>View Mode
                    </label>
                </div>
                <div class="d-flex justify-content-between align-items-center gap-3">
                    <div class="flex-grow-1" style="max-width: 450px;">
                        <input type="text" 
                               id="equipmentSearch" 
                               class="form-control" 
                               @bind="SearchTerm" 
                               @bind:event="oninput"
                               placeholder="Search by ID, Physical ID, Name, or Category..." />
                    </div>
                    <div class="btn-group" role="group">
                        <button type="button" 
                                class="btn @(isCardView ? "btn-primary" : "btn-outline-primary")" 
                                @onclick="() => isCardView = true">
                            <i class="bi bi-grid-3x3-gap"></i> Cards
                        </button>
                        <button type="button" 
                                class="btn @(!isCardView ? "btn-primary" : "btn-outline-primary")" 
                                @onclick="() => isCardView = false">
                            <i class="bi bi-table"></i> Table
                        </button>
                    </div>
                </div>
                <small class="text-muted d-block mt-2">
                    <i class="bi bi-info-circle"></i> Showing @filteredAssets.Count of @assets.Count items
                </small>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @message
            <button type="button" class="btn-close" @onclick="@(() => message = string.Empty)" aria-label="Close"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = string.Empty)" aria-label="Close"></button>
        </div>
    }

    <AuthorizeView Roles="Admin,Teacher" Context="authContext">
        <Authorized>
            @if (showAddForm)
            {
                <div class="card modern-card mb-5">
                    <div class="card-header">
                        <h5><i class="bi bi-plus-square me-2"></i>Add New Equipment</h5>
                    </div>
                    <div class="card-body">
                        <EditForm Model="newAsset" OnValidSubmit="HandleAddAssetAsync">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger" />

                            <div class="row g-4 mb-3">
                                <div class="col-md-4 mb-3 mb-md-0">
                                    <label for="assetPhysicalId" class="form-label">
                                        <i class="bi bi-upc-scan me-1"></i>Physical ID
                                    </label>
                                    <InputText id="assetPhysicalId" class="form-control" @bind-Value="newAsset.PhysicalId" placeholder="e.g., HSP-001" />
                                </div>

                                <div class="col-md-4 mb-3 mb-md-0">
                                    <label for="assetName" class="form-label">
                                        <i class="bi bi-tag me-1"></i>Asset Name
                                    </label>
                                    <InputText id="assetName" class="form-control" @bind-Value="newAsset.Name" placeholder="e.g., Laptop Dell XPS 15" />
                                </div>

                                <div class="col-md-4">
                                    <label for="assetCategory" class="form-label">
                                        <i class="bi bi-folder me-1"></i>Category
                                    </label>
                                    <InputText id="assetCategory" class="form-control" @bind-Value="newAsset.Category" placeholder="e.g., Electronics, Books" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-check custom-checkbox-lg d-flex align-items-center">
                                    <InputCheckbox id="assetAvailable" class="form-check-input me-2" @bind-Value="newAsset.IsAvailable" />
                                    <label class="form-check-label mb-0" for="assetAvailable">
                                        Available for Loan
                                    </label>
                                </div>
                            </div>

                            <div class="action-buttons mt-4">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-save me-2"></i>Save Asset
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="CancelAddAsset">
                                    <i class="bi bi-x-circle me-2"></i>Cancel
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </Authorized>
    </AuthorizeView>

    @if (assets == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading equipment...</p>
        </div>
    }
    else if (!assets.Any())
    {
        <div class="empty-state text-center py-5">
            <i class="bi bi-inbox empty-icon"></i>
            <h4 class="mt-3">No Equipment Found</h4>
            <p class="text-muted">Get started by adding your first equipment to the inventory.</p>
            <AuthorizeView Roles="Admin,Teacher">
                <Authorized>
                    <button class="btn btn-primary mt-3" @onclick="ShowAddAssetForm">
                        <i class="bi bi-plus-circle me-2"></i>Add Your First Equipment
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    }
    else
    {
        @if (isCardView)
        {
            <!-- Category Summary Section -->
            @if (GetFilteredCategories().Any())
            {
                <div class="category-summary mb-5">
                    <h3 class="mb-4 text-center">
                        <i class="bi bi-grid-3x3-gap me-2"></i>Available Equipment by Category
                    </h3>
                    <div class="category-grid">
                        @foreach (var category in GetFilteredCategories())
                        {
                            var categoryAssets = filteredAssets.Where(a => a.Category == category).ToList();
                            var availableCount = categoryAssets.Count(a => a.IsAvailable);

                            <div class="category-card">
                                <div class="category-icon">
                                    @GetCategoryIcon(category)
                                </div>
                                <h5 class="category-title">@category</h5>
                                <p class="category-count">@categoryAssets.Count items</p>
                                <div class="category-status">
                                    <span class="badge bg-success">@availableCount Available</span>
                                    <span class="badge bg-warning">@(categoryAssets.Count - availableCount) On Loan</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- All Equipment Grid -->
            <div class="equipment-section">
                <h3 class="mb-4 text-center">
                    <i class="bi bi-list-ul me-2"></i>All Equipment
                    <span class="text-muted fs-6">(@filteredAssets.Count items)</span>
                </h3>

                @if (!filteredAssets.Any())
                {
                    <div class="empty-state text-center py-5">
                        <i class="bi bi-search empty-icon"></i>
                        <h4 class="mt-3">No Equipment Found</h4>
                        <p class="text-muted">No equipment matches your search criteria.</p>
                        <button class="btn btn-secondary mt-3" @onclick="ClearSearch">
                            <i class="bi bi-x-circle me-2"></i>Clear Search
                        </button>
                    </div>
                }
                else
                {
                    <div class="equipment-grid">
                        @foreach (var asset in filteredAssets)
                        {
                            <div class="equipment-card @(asset.IsAvailable ? "available" : "unavailable")">
                                <div class="equipment-card-header">
                                    <div class="equipment-icon">
                                        @GetEquipmentIcon(asset.Category)
                                    </div>
                                    <div class="equipment-status-badge">
                                        @if (asset.IsAvailable)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i>Available
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                <i class="bi bi-clock me-1"></i>On Loan
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="equipment-card-body">
                                    <h5 class="equipment-name">@asset.Name</h5>

                                    <div class="equipment-details">
                                        <div class="equipment-detail-item">
                                            <i class="bi bi-hash text-primary"></i>
                                            <span class="detail-label">ID:</span>
                                            <span class="badge bg-secondary">@asset.ItemId</span>
                                        </div>

                                        <div class="equipment-detail-item">
                                            <i class="bi bi-upc-scan text-primary"></i>
                                            <span class="detail-label">Physical ID:</span>
                                            <span class="badge bg-info">@asset.PhysicalId</span>
                                        </div>

                                        <div class="equipment-detail-item">
                                            <i class="bi bi-folder-fill text-primary"></i>
                                            <span class="detail-label">Category:</span>
                                            <span>@asset.Category</span>
                                        </div>
                                    </div>
                                </div>

                                <AuthorizeView Roles="Admin,Teacher">
                                    <Authorized>
                                        <div class="equipment-card-footer">
                                            <button class="btn btn-danger btn-sm w-100" @onclick="@(() => DeleteAssetAsync(asset))">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Table View -->
            <div class="card modern-card">
                <div class="card-header">
                    <h5><i class="bi bi-table me-2"></i>Equipment List</h5>
                </div>
                <div class="card-body">
                    @if (!filteredAssets.Any())
                    {
                        <div class="empty-state text-center py-5">
                            <i class="bi bi-search empty-icon"></i>
                            <h4 class="mt-3">No Equipment Found</h4>
                            <p class="text-muted">No equipment matches your search criteria.</p>
                            <button class="btn btn-secondary mt-3" @onclick="ClearSearch">
                                <i class="bi bi-x-circle me-2"></i>Clear Search
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table modern-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Physical ID</th>
                                        <th>Name</th>
                                        <th>Category</th>
                                        <th>Status</th>
                                        <AuthorizeView Roles="Admin,Teacher">
                                            <Authorized>
                                                <th>Actions</th>
                                            </Authorized>
                                        </AuthorizeView>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var asset in filteredAssets)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">@asset.ItemId</span></td>
                                            <td><span class="badge bg-info">@asset.PhysicalId</span></td>
                                            <td class="fw-semibold">@asset.Name</td>
                                            <td>
                                                <i class="bi bi-folder-fill text-primary me-1"></i>
                                                @asset.Category
                                            </td>
                                            <td>
                                                @if (asset.IsAvailable)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle me-1"></i>Available
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">
                                                        <i class="bi bi-clock me-1"></i>On Loan
                                                    </span>
                                                }
                                            </td>
                                            <AuthorizeView Roles="Admin,Teacher">
                                                <Authorized>
                                                    <td>
                                                        <button class="btn btn-danger btn-sm" @onclick="@(() => DeleteAssetAsync(asset))" title="Delete asset">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </Authorized>
                                            </AuthorizeView>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="table-footer mt-3">
                            <p class="text-muted mb-0">
                                <i class="bi bi-info-circle me-1"></i>
                                Showing <strong>@filteredAssets.Count</strong> of <strong>@assets.Count</strong> asset(s)
                            </p>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>